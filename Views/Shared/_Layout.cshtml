@{
    string name = User.Identity?.Name ?? "";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Arvind and Sons</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MvcApp.styles.css" asp-append-version="true" />

</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light shadow-sm mb-3">
            <div class="container-fluid">
                <!-- Brand -->
                <a class="navbar-brand fw-bold text-primary" asp-controller="Home" asp-action="Index">ArvindAndSons</a>

                <!-- Left Menu -->
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-semibold" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-primary fw-bold" asp-controller="Cart" asp-action="Index">🛒 Shop Cart</a>
                        </li>
                        <li>
                            <a class="nav-link text-dark fw-semibold" asp-area="" asp-controller="Home" asp-action="RND">Reasearch and Development</a>
                        </li>
                        <li>
                            <a class="nav-link text-dark fw-semibold" asp-area="" asp-controller="Home" asp-action="News">News</a>
                        </li>
                        <li>
                            <a class="nav-link text-dark fw-semibold" asp-area="" asp-controller="Home" asp-action="Blog">Blog</a>
                        </li>
                        <li>
                            <a class="nav-link text-dark fw-semibold" asp-area="" asp-controller="Home" asp-action="AboutUs">About US</a>
                        </li>
                        <li>
                            <a class="nav-link text-dark fw-semibold" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                    </ul>
                </div>

                <!-- right Menu -->
                <div class="justify-content-end">
                    <ul class="navbar-nav flex-grow-1">
                        @if (!User.Identity.IsAuthenticated)
                        {
                        <li class="nav-item">
                            <a class="nav-link btn btn-outline-primary  px-3 mx-1" asp-controller="Home" asp-action="Registration">Registration</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link btn btn-outline-primary  px-3 mx-1" asp-controller="Home" asp-action="Login">Login</a>
                        </li>
                        }
                        else
                        {
                        <li class="nav-item d-flex align-items-center">
                            <span class="nav-link fw-semibold text-dark">
                                Hi 👋 @User.Identity.Name
                            </span>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link btn btn-outline-danger" asp-controller="Home" asp-action="Logout">Logout</a>
                        </li>

                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
             2026 - MvcApp - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
