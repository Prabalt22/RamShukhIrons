using Microsoft.AspNetCore.Authentication.Cookies;
using ArvindamIrons.Services;


var builder = WebApplication.CreateBuilder(args);
string conStr = builder.Configuration["ConnectionStrings:connectionStr"] ?? "";

// Add services to the container.
builder.Services.AddControllersWithViews();
builder.Services.AddScoped<DAL>(provider => new DAL(conStr));


//Session setting
builder.Services.AddDistributedMemoryCache();
builder.Services.AddSession(options =>
{
    options.IdleTimeout = TimeSpan.FromMinutes(30);
    options.Cookie.HttpOnly = true;
    options.Cookie.IsEssential = true;
});

// to use services
builder.Services.AddHttpClient<NewServices>();

builder.Services.AddAuthentication(CookieAuthenticationDefaults.AuthenticationScheme).AddCookie(
    option => {
        option.LoginPath = "/Home/Login";   //Redirects to login page
        option.LogoutPath = "/Home/Logout"; //Redirects after Logout
        option.ExpireTimeSpan = TimeSpan.FromMinutes(30);
        option.SlidingExpiration = true;    // extent expiration on activity        
    });


// I Add this explicitly
builder.Services.AddSession();


var app = builder.Build();

// Configure the HTTP request pipeline.
if (!app.Environment.IsDevelopment())
{
    app.UseExceptionHandler("/Home/Error");
    // The default HSTS value is 30 days. You may want to change this for production scenarios, see https://aka.ms/aspnetcore-hsts.
    app.UseHsts();
}

app.UseHttpsRedirection();
app.UseStaticFiles();

app.UseRouting();
app.UseAuthorization();
app.UseAuthorization();

app.MapControllerRoute(
    name: "default",
    pattern: "{controller=Home}/{action=Index}/{id?}");

app.Run();
